<div class="container mt-5">
  <div class="card shadow-sm">
    <div class="card-body">
      <h3 class="card-title"><%= @employee.name %></h3>
      <h5 class="card-subtitle mb-3 text-muted">Designation: <%= @employee.designation %></h5>

      <div class="mt-4">
        <%= link_to '✏️ Edit', edit_employee_path(@employee), class: "btn btn-warning" %>
        <%= link_to '🗑️ Delete', employee_path(@employee), method: :delete, data: { confirm: 'Are you sure?' }, class: "btn btn-danger" %>
        <%= link_to '⬅️ Back to List', employees_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>
